# LLM Provider Configuration
# The stack uses the OpenAI-compatible SDK, so any provider works by
# setting LLM_API_KEY + LLM_BASE_URL + LLM_MODEL.

# --- Together AI (recommended) ---
LLM_API_KEY=your-together-ai-key-here
LLM_BASE_URL=https://api.together.xyz/v1
LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# --- OpenAI (alternative) ---
# LLM_API_KEY=sk-your-openai-key-here
# LLM_BASE_URL=
# LLM_MODEL=gpt-4o-mini

# --- Infinigence (alternative) ---
# LLM_API_KEY=your-infinigence-key-here
# LLM_BASE_URL=https://cloud.infini-ai.com/maas/v1
# LLM_MODEL=qwen2.5-72b-instruct

# Data directory (output of stream_data.py)
DATA_DIR=./data

# Service ports (task-a uses 8001, task-b uses 8002)
PORT=8001
HOST=0.0.0.0

# Agent Configuration
ENABLE_NIGERIAN_CONTEXT=true

# Logging
LOG_LEVEL=INFO
